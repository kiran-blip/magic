# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ══════════════════════════════════════════════════════════════════════
# SECRETS & API KEYS — NEVER commit these
# ══════════════════════════════════════════════════════════════════════

# Environment files (contain API keys, JWT secrets)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
!.env.example

# Gold Digger runtime data (contains encrypted API keys in config)
/data/
data/
vault.enc
**/vault.enc

# Broker credentials and config
golddigger-config.json
**/golddigger-config.json

# Any key/credential/secret files
*.key
*.pem
*.cert
*.p12
*.pfx
*.jks
*credentials*
*secret*
!**/credential-detector.ts
!**/credential-detector.test.ts

# ══════════════════════════════════════════════════════════════════════
# BUILD & DEPENDENCIES
# ══════════════════════════════════════════════════════════════════════

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite databases (may contain sensitive conversation data)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
